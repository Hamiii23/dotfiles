{
  "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/src/config/swaync-config-schema.json",

  "positionX": "right",
  "positionY": "top",

  "timeout": 5,
  "timeout-low": 5,
  "timeout-critical": 0,

  "notification-window-width": 400,
  "notification-icon-size": 64,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,

  "control-center-exclusive-zone": false,
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "control-center-width": 320,
  "control-center-height": 0,

  "fit-to-screen": true,

  "hide-on-clear": false,
  "hide-on-action": false,

  "keyboard-shortcuts": false,

  "do-not-disturb": false,
  "do-not-disturb-button-text": "Do Not Disturb",

  "transition-time": 200,

  "layer": "overlay",
  "control-center-layer": "overlay",

  "widgets": ["title", "dnd", "notifications"],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "notifications": {
      "notification-visibility": {
        "example-name": {
          "state": "enabled"
        }
      }
    }
  }
}
